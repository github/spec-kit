{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "speckit.behavior.open-questions.v1.schema.json",
  "title": "Spec Kit Behavior Open Questions",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_type", "questions"],
  "properties": {
    "contract_type": {
      "const": "speckit.behavior.open_questions.v1"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "question", "reason", "status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "question": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "status": {"enum": ["open", "answered", "deferred"]}
        }
      }
    }
  }
}

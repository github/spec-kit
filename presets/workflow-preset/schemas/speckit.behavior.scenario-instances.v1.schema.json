{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "speckit.behavior.scenario-instances.v1.schema.json",
  "title": "Spec Kit Behavior Scenario Instances",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_type", "scenarios"],
  "properties": {
    "contract_type": {
      "const": "speckit.behavior.scenario_instances.v1"
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "type",
          "uif_path_id",
          "fixture_ids",
          "request_case",
          "expected_response",
          "expected_feedback",
          "assertion_ids"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "type": {
            "enum": ["positive", "negative", "boundary", "permission", "validation", "state_conflict"]
          },
          "uif_path_id": {"type": "string", "minLength": 1},
          "fixture_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "request_case": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id"],
            "properties": {
              "id": {"type": "string", "minLength": 1}
            }
          },
          "expected_response": {
            "type": "object",
            "additionalProperties": true
          },
          "expected_feedback": {
            "type": "object",
            "additionalProperties": true
          },
          "assertion_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    }
  }
}
